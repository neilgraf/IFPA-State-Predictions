# Copy this file to .env and fill in real values.
# .env should never be committed to source control.

# Generate at https://app.matchplay.events/account/tokens
MATCHPLAY_API_TOKEN=

# Request at https://www.ifpapinball.com/api/documentation/
IFPA_API_KEY=

# Only needed once backend/db/schema.sql is wired up to a real database.
DATABASE_URL=postgresql://user:password@localhost:5432/pinball_predictions
